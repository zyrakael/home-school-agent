# App
APP_ENV=local

# MCP
# Agent-side connection to the standalone sibling project: ../mcp-data-service.
MCP_SERVERS='[{"name":"data","transport":"streamable_http","url":"http://127.0.0.1:8100/mcp","headers":{"Authorization":"Bearer change-me-to-a-long-random-token"},"tool_prefixes":["user","learning","wrong_question","lesson"],"timeout_seconds":10}]'
MCP_DEFAULT_TIMEOUT_SECONDS=10

# LLM (DashScope / Qwen)
DASHSCOPE_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_CHAT_MODEL=qwen-plus
